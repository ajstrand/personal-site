  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "trash": "trash public build dist",
    "test": "jest",
    "dev": "yarn trash && yarn prep && node viteServer",
    "pre":"gleam build && gleam run",
    "prep": "mkdir public && yarn pre  && yarn rename",
    "rename": "node renameFiles.js",
    "build": "yarn rename && yarn run build:client && yarn run build:server && node --experimental-specifier-resolution=node prerender",
