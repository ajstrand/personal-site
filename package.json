{
  "name": "tropical",
  "version": "11.4.1",
  "dependencies": {
    "@ladle/react": "^2.5.2",
    "@mdx-js/mdx": "^2.2.1",
    "@mdx-js/preact": "2.2.1",
    "@mdx-js/react": "^2.2.1",
    "@mdx-js/rollup": "^2.2.1",
    "@stefanprobst/rehype-extract-toc": "^2.2.0",
    "@vitejs/plugin-react": "^3.0.1",
    "dayjs": "^1.11.7",
    "express": "^4.18.2",
    "fela": "^12.0.2",
    "fela-dom": "^12.0.2",
    "fs-extra": "^10.0.0",
    "preact-fela": "^12.2.1",
    "preact-render-to-string": "^5.2.6",
    "react": "npm:@preact/compat@^17.1.2",
    "react-dom": "npm:@preact/compat@^17.1.2",
    "react-fela": "^12.0.2",
    "react-head": "^3.4.0",
    "react-syntax-highlighter": "^15.5.0",
    "rehype-slug": "^5.1.0",
    "remark-gfm": "^3.0.1",
    "rollup": "^3.12.0",
    "tropical-islands": "github:ajstrand/tropical-utils#preact-version",
    "tropical-scaffold": "^2.0.0",
    "vite": "^4.0.4",
    "vite-plugin-image-presets": "^0.3.4",
    "yarpm": "^1.2.0"
  },
  "engines": {
    "node": ">=16"
  },
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "node server",
    "build": "yarpm run build:clientAssets && yarpm run build:server && node --experimental-specifier-resolution=node prerender",
    "build:clientAssets": "vite --config vite.config.client.js build --outDir dist/static",
    "build:server": "vite --config vite.config.server.js build --outDir dist/server --ssr src/entry-server.jsx",
    "stories": "ladle serve -p 6006",
    "page": "tropical-scaffold --type=page",
    "component": "tropical-scaffold --type=component"
  },
  "tropical": {
    "siteHost": "https://www.example.org"
  }
}
